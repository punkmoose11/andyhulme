HTML <- gsub("YEAR2",paste("<a href='bracket",paste(j+1),".html'>",paste(j+1),"</a>",sep=""),HTML)
HTML <- gsub("<< <a href='bracket2005.html'>2005</a> ","<< <a href='bracket2004.html'>2004</a> ",HTML)
